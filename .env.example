# =============================================================================
# Verbatim.ai — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in values as you wire up each service.
# Day 1 requires only NEXT_PUBLIC_APP_URL. Everything else is filled in Day 2+.
# =============================================================================

# ---- Core ------------------------------------------------------------------
# Day 1. In production: https://app.joinverbatim.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Clerk (Day 3) ---------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/projects
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/projects

# ---- Supabase (Day 2) ------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ SERVER-ONLY. Never import this into a file marked "use client".
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic (Week 2) ----------------------------------------------------
# Apply for Anthropic Startup credits before you spend a dollar.
ANTHROPIC_API_KEY=

# ---- OpenAI embeddings (Week 2) --------------------------------------------
OPENAI_API_KEY=

# ---- AssemblyAI (Week 1 Mon) -----------------------------------------------
ASSEMBLYAI_API_KEY=
# Webhook secret for AssemblyAI → /api/webhooks/assemblyai
ASSEMBLYAI_WEBHOOK_AUTH=

# ---- Inngest (Week 1 Mon) --------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Stripe (Week 3 Sun) ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=

# ---- Resend (Week 3) -------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_ADDRESS=hello@joinverbatim.com

# ---- Upstash Redis (rate limiting, Week 3 Wed) -----------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Observability (Week 3 Wed) --------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=verbatim-prod

# ---- Admin gate ------------------------------------------------------------
# Comma-separated emails that can access /admin. Your address only at first.
ADMIN_EMAILS=dhanush@joinverbatim.com
